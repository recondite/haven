# ─── Server ──────────────────────────────────────────────
HAVEN_HOST=127.0.0.1
HAVEN_PORT=8765

# ─── LLM (Option 1 — shell out to claude CLI) ────────────
HAVEN_LLM_MODE=cli
HAVEN_LLM_MODEL=claude-sonnet-4-6
HAVEN_LLM_MODEL_CHEAP=claude-haiku-4-5
# Optional: explicit absolute path to the `claude` executable.
# Use this when the FastAPI subprocess can't find it on PATH (run `where claude`
# in your terminal to find it). Examples:
#   HAVEN_CLAUDE_CLI=C:\Users\GarthThompson\AppData\Roaming\npm\claude.cmd
#   HAVEN_CLAUDE_CLI=C:\Program Files\nodejs\claude.cmd
# HAVEN_CLAUDE_CLI=

# ─── Slack ───────────────────────────────────────────────
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-...
SLACK_USER_TOKEN=xoxp-...
SLACK_APP_TOKEN=xapp-1-...

# ─── Google / Gmail (Web OAuth client) ───────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8765/oauth/callback
GOOGLE_PROJECT_ID=

# ─── Linear ──────────────────────────────────────────────
LINEAR_API_KEY=
LINEAR_PROJECT_ID=25318105-c93f-424d-a877-d5359bb00ba2

# ─── JIRA ────────────────────────────────────────────────
JIRA_BASE_URL=https://ayarlabs.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# ─── Freshservice ────────────────────────────────────────
FRESHSERVICE_DOMAIN=ayarlabs.freshservice.com
FRESHSERVICE_API_KEY=

# ─── Auth ────────────────────────────────────────────────
# Token required on every endpoint. Leave blank to disable (localhost dev).
# Browser: native Basic prompt (any username, this as password).
# API/CLI: Authorization: Bearer <token>
HAVEN_AUTH_TOKEN=

# ─── Send mode ───────────────────────────────────────────
# dry (default): approving a draft records the action, sends nothing.
# live: the executor actually posts (Slack) / sends (Gmail) on Approve.
HAVEN_SEND_MODE=dry
